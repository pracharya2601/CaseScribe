# CaseScribe — local dev environment.
# Copy to `.env` (gitignored). On GMI AgentBox these are auto-injected; never hardcode.

# Bearer token for GMI MaaS.
GMI_MAAS_API_KEY=sk-your-maas-key-here

# OpenAI-compatible MaaS endpoint.
GMI_MAAS_BASE_URL=https://api.gmi-serving.com/v1

# Target model ID(s) from the listing wizard (comma-separated if multiple).
GMI_MODELS=nvidia/NVIDIA-Nemotron-3-Nano-Omni,Qwen/Qwen3-Next-80B-A3B-Instruct,Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8,anthropic/claude-sonnet-4.6
