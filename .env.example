# CaseScribe — local dev environment.
# Copy to `.env` (gitignored). On GMI AgentBox these are auto-injected; never hardcode.

# Bearer token for GMI MaaS.
GMI_MAAS_API_KEY=sk-your-maas-key-here

# OpenAI-compatible MaaS endpoint.
GMI_MAAS_BASE_URL=https://api.gmi-serving.com/v1

# Target model ID(s) from the listing wizard (comma-separated if multiple).
GMI_MODELS=nvidia/NVIDIA-Nemotron-3-Nano-Omni,Qwen/Qwen3-Next-80B-A3B-Instruct,Qwen/Qwen3-Coder-480B-A35B-Instruct-FP8,anthropic/claude-sonnet-4.6

! for M in "zai-org/GLM-5.2-FP8" "Qwen/Qwen3.6-Max-Preview" "anthropic/claude-opus-4.8"; do
  echo "===== $M ====="
  curl -s https://api.gmi-serving.com/v1/chat/completions \
    -H "Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjljNTJjMzIwLTM4YWItNDU1MC04MmEzLTQ3NmU5N2Y3NmQ4NiIsInNjb3BlIjoiaWVfbW9kZWwiLCJjbGllbnRJZCI6IjAwMDAwMDAwLTAwMDAtMDAwMC0wMDAwLTAwMDAwMDAwMDAwMCJ9.AEBBRIEzym6MTOM5gqiODjbRkX0ih4jlNjCSfD7LSHY" -H "Content-Type: application/json" \
    -d "{\"model\":\"$M\",\"messages\":[{\"role\":\"user\",\"content\":\"Reply with JSON {\\\"ok\\\":true}\"}],\"max_tokens\":20,\"response_format\":{\"type\":\"json_object\"}}" \
    | head -c 500; echo; echo
done