# CaseScribe agent — local dev environment.
# Copy to `.env` (gitignored). On GMI AgentBox these are auto-injected; never hardcode.

# Bearer token for GMI MaaS.
GMI_MAAS_API_KEY=sk-your-maas-key-here

# OpenAI-compatible MaaS endpoint.
GMI_MAAS_BASE_URL=https://api.gmi-serving.com/v1

# Per-sub-agent model routing (GMI_MODEL_<STEP> wins over the GMI_MODELS blob).
GMI_MODEL_CLASSIFIER=deepseek-ai/DeepSeek-V4-Flash
GMI_MODEL_REPORTER=zai-org/GLM-5.2-FP8
GMI_MODEL_MEDICAID=Qwen/Qwen3.6-Max-Preview
GMI_MODEL_CASENOTE=anthropic/claude-opus-4.8
GMI_MODEL_REPORTER_ESCALATION=anthropic/claude-opus-4.8
