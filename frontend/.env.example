# CaseScribe frontend — local dev / demo config. Copy to `.env.local`.

# The deployed agent's URL (AgentBox public URL). The UI runs locally and calls
# this cross-origin. Leave empty to use same-origin relative paths (only works
# if a backend runs on the same host).
#   e.g. VITE_API_BASE=https://ct-<uuid>-web.caas-... .gmicloud.ai
VITE_API_BASE=

# Force mock data instead of the live agent (back-compat; runtime ?mock=1 also works).
# VITE_USE_MOCK=false
